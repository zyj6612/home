// 定义LED引脚，ESP32通常板载LED连接在GPIO 2
const int ledPin = 2; 

// millis()计时相关变量
unsigned long previousMillis = 0;  // 记录上一次LED状态变化的时间
const long interval = 1000;        // 状态切换间隔：1000ms（1秒）
bool ledState = LOW;               // 记录LED当前状态

void setup() {
  // 初始化串口通信，设置波特率为115200
  Serial.begin(115200);
  // 将LED引脚设置为输出模式
  pinMode(ledPin, OUTPUT);
}

void loop() {
  // 获取当前系统运行时间（毫秒）
  unsigned long currentMillis = millis();

  // 判断是否到达切换状态的时间点
  if (currentMillis - previousMillis >= interval) {
    previousMillis = currentMillis;  // 更新时间戳
    ledState = !ledState;            // 翻转LED状态（HIGH ↔ LOW）
    digitalWrite(ledPin, ledState);  // 输出到LED引脚

    // 串口输出提示，和原代码保持一致
    if (ledState == HIGH) {
      Serial.println("LED ON");
    } else {
      Serial.println("LED OFF");
    }
  }
}
